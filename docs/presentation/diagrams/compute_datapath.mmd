flowchart LR
  Q["Query HV<br/>16 × 64-bit words"]
  P["Prototype k<br/>16 × 64-bit words"]
  M["Mask word w<br/>(pruning_mask)"]
  XOR["XOR<br/>64-bit"]
  AND["AND mask<br/>64-bit"]
  POP["popcount64<br/>adder tree (LUTs)"]
  ACC["+ accumulate<br/>distance d_k"]
  CMP["argmin over k<br/>first-index tie"]
