flowchart LR
  subgraph PS["Processing System — ARM Cortex-A9 @ 650 MHz"]
    direction TB
    APP["Bare-metal C app"]
    DDR["DDR memory<br/>EMG windows"]
    DMA["AXI DMA engine<br/>scatter-gather"]
    APP --> DDR --> DMA
  end
  subgraph PL["Programmable Logic — FPGA @ 100 MHz"]
    direction TB
    WRAP["AXI4-Lite control +<br/>AXI4-Stream data"]
    ENC["encoder_top<br/>window → query HV"]
    MASK["pruning_mask<br/>Hook A"]
    AM["popcount_am<br/>nearest prototype"]
    WRAP --> ENC --> AM
    MASK -. gates bits .-> AM
  end
  DMA == stream windows ==> WRAP
  AM == class label ==> WRAP
  WRAP == results ==> DMA
