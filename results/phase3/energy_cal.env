# Phase 3 INA219 calibration (J21 sense path on ZedBoard).
# Sourced automatically by run_energy_log_pi.sh and manual logs.
#
# Re-measure J21 with a multimeter (mV DC, SW8 ON) if wiring changes.
# gain ≈ ref_mV / raw INA219 shunt_mV at idle.

export INA219_BUS=1
export INA219_SHUNT_MOHM=10
export INA219_V_RAIL=12.0
export INA219_CAL_REF_MV=2.0
